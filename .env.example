# =============================================================================
# Aqarat — Environment Variables
# Copy this file to `.env` for local development (loaded by docker-compose).
# Each app also has its own `.env` (apps/backend/.env, apps/frontend/.env).
# =============================================================================

# --- Application ---
NODE_ENV=development
APP_NAME=Aqarat
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# --- Backend ---
BACKEND_PORT=3000
JWT_ACCESS_SECRET=change_me_in_production_min_32_chars_long_secret
JWT_REFRESH_SECRET=change_me_too_in_production_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5532
POSTGRES_USER=aqarat
POSTGRES_PASSWORD=aqarat_dev_password
POSTGRES_DB=aqarat
POSTGRES_SSL=false

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6479
REDIS_PASSWORD=
REDIS_DB=0

# --- Kafka ---
KAFKA_BROKERS=localhost:9094
KAFKA_CLIENT_ID=aqarat-backend
KAFKA_GROUP_ID=aqarat-backend-group

# --- AWS / SES (transactional email) ---
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=no-reply@aqarat.sa
SES_REPLY_TO=support@aqarat.sa

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# --- Authentica (Saudi identity / OTP) ---
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=https://api.authentica.sa

# --- Moyasar (payments) ---
MOYASAR_SECRET_KEY=
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_WEBHOOK_SECRET=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# --- Frontend (Vite — must be prefixed with VITE_) ---
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
VITE_GOOGLE_MAPS_API_KEY=
VITE_MOYASAR_PUBLISHABLE_KEY=
VITE_DEFAULT_LOCALE=ar
VITE_SUPPORTED_LOCALES=ar,en
