# Frontend environment variables (Vite — only VITE_-prefixed vars are exposed)

# API + realtime
VITE_API_URL=http://localhost:3011/api/v1
VITE_SOCKET_URL=http://localhost:3011

# Google Maps JS API key
VITE_GOOGLE_MAPS_API_KEY=

# Google Analytics 4 measurement id (optional — analytics no-op when unset)
VITE_GA_MEASUREMENT_ID=

# PostHog product analytics (optional — analytics no-op when key unset)
VITE_POSTHOG_KEY=phc_your_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry error tracking (optional — no-op when unset). Only enabled in prod
# builds and bypassed on localhost so dev sessions stay quiet.
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
