{
  "name": "eawlma",
  "version": "0.1.0",
  "private": true,
  "description": "eawlma — Saudi/GCC real estate platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:types": "npm run build -w @eawlma/shared-types",
    "build:backend": "npm run build -w @eawlma/backend",
    "build:frontend": "npm run build -w @eawlma/frontend",
    "build": "npm run build:types && npm run build:backend && npm run build:frontend",
    "dev:backend": "npm run start:dev -w @eawlma/backend",
    "dev:frontend": "npm run dev -w @eawlma/frontend",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test -w @eawlma/backend",
    "test:backend:coverage": "npm run test:cov -w @eawlma/backend",
    "test:frontend": "npm run test:unit -w @eawlma/frontend",
    "test:e2e": "npm run test:e2e -w @eawlma/frontend",
    "test:e2e:ui": "npm run test:e2e:ui -w @eawlma/frontend",
    "test:e2e:headed": "npm run test:e2e:headed -w @eawlma/frontend",
    "test:e2e:debug": "npm run test:e2e:debug -w @eawlma/frontend",
    "test:report": "npm run test:e2e && npm run test:report:generate -w @eawlma/frontend",
    "test:all": "npm run test:backend && npm run test:frontend && npm run test:e2e",
    "test:api": "npm run test:api-coverage -w @eawlma/backend",
    "test:load": "npm run test:load -w @eawlma/backend",
    "test:load:report": "npm run test:load:report -w @eawlma/backend",
    "test:full": "npm run test:api && npm run test:frontend && npm run test:e2e",
    "test:report:full": "npm run test:e2e && node apps/frontend/e2e/full-report.mjs",
    "test:open:report": "start apps/frontend/playwright-report/eawlma-full-report.html",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
