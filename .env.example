# =============================================================================
# Aqarat — Environment Variables (root)
# =============================================================================
#
# Loaded by `docker-compose.yml` and (as a fallback) by the backend's
# NestJS ConfigModule. Frontend bundles only `VITE_*` variables.
#
# Copy to `.env` and fill in real secrets. Never commit `.env`.
# =============================================================================

# ─── Application ───
# Set to 'production' only when deploying live. Development/staging values
# keep external integrations (e.g. Moyasar disbursements) in mock mode so we
# never hit "Resource not found" against a Moyasar account that doesn't yet
# have the disbursements add-on enabled.
NODE_ENV=development
APP_NAME=Aqarat
APP_URL=http://192.168.1.125:5173
API_URL=http://192.168.1.125:3000
CORS_ORIGINS=http://192.168.1.125:5173,http://192.168.1.125:4173
DEFAULT_LOCALE=ar
SUPPORTED_LOCALES=ar,en

# ─── Backend ───
BACKEND_PORT=3000
API_PREFIX=api
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── JWT (REQUIRED — generate two strong secrets, ≥ 32 chars each) ───
# Tip: openssl rand -hex 48
JWT_ACCESS_SECRET=change_me_in_production_min_32_chars_long_secret
JWT_REFRESH_SECRET=change_me_too_in_production_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=aqarat
JWT_AUDIENCE=aqarat-clients

# ─── PostgreSQL ───
# Host port (5532) is non-standard so this stack coexists with other Postgres
# instances on the same machine. Inside the docker network: postgres:5432.
POSTGRES_HOST=192.168.1.125
POSTGRES_PORT=5532
POSTGRES_USER=aqarat
POSTGRES_PASSWORD=aqarat_dev_password
POSTGRES_DB=aqarat
POSTGRES_SSL=false
PG_POOL_MAX=20
TYPEORM_LOGGING=false

# ─── Redis ───
REDIS_HOST=192.168.1.125
REDIS_PORT=6479
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=aqarat:

# ─── Kafka ───
KAFKA_BROKERS=192.168.1.125:9094
KAFKA_CLIENT_ID=aqarat-backend
KAFKA_GROUP_ID=aqarat-backend-group
KAFKA_SSL=false
KAFKA_TOPIC_LISTING_EVENTS=aqarat.listing.events
KAFKA_TOPIC_TRANSLATION_JOBS=aqarat.translation.jobs
KAFKA_TOPIC_ANALYTICS=aqarat.analytics.events
KAFKA_TOPIC_NOTIFICATIONS=aqarat.notifications.fanout

# ─── AWS — shared (used by SES + S3) ───
# When AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY are missing, SES and S3
# transparently switch to dev-stub mode so the app keeps working in dev.
AWS_REGION=me-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── AWS / SES (transactional email) ───
SES_FROM_EMAIL=no-reply@aqarat.sa
SES_REPLY_TO=support@aqarat.sa

# ─── AWS / S3 + CloudFront (media, avatars, AR models) ───
S3_BUCKET=aqarat-uploads-dev
S3_REGION=me-south-1
S3_PRESIGN_EXPIRES_SECONDS=900
# Optional CDN prefix; when set, public URLs return https://${CLOUDFRONT_URL}/<key>
CLOUDFRONT_URL=

# ─── OpenAI (gpt-4o — translation, description enhance, recommendations) ───
# Empty key → backend returns deterministic stub responses.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2000

# ─── Authentica.sa (Saudi national-ID + phone OTP verification) ───
# Empty key → /auth/authentica/* returns a stub verification ID for E2E tests.
AUTHENTICA_API_KEY=
AUTHENTICA_BASE_URL=https://api.authentica.sa
AUTHENTICA_WEBHOOK_SECRET=

# ─── Moyasar (payments) ───
MOYASAR_SECRET_KEY=
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_WEBHOOK_SECRET=
MOYASAR_API_URL=https://api.moyasar.com/v1

# ─── Google Maps ───
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# ─── Frontend (Vite — only VITE_*-prefixed vars are exposed to the bundle) ───
VITE_API_URL=http://192.168.1.125:3000
VITE_SOCKET_URL=http://192.168.1.125:3000
VITE_GOOGLE_MAPS_API_KEY=
VITE_MOYASAR_PUBLISHABLE_KEY=
VITE_DEFAULT_LOCALE=ar
VITE_SUPPORTED_LOCALES=ar,en
