# Native build output. We use Expo Go for development; these directories are
# regenerated on demand by `npx expo prebuild` / `expo run:*`. Committing them
# would mean every dev's local Gradle/Pods cache state ends up in git.
android/
ios/

*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

